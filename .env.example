# Copy this to .env and fill in your values
# NEVER commit .env to git

FLASK_APP=run.py
FLASK_ENV=production
DEBUG=False

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# PostgreSQL connection
DATABASE_URL=postgresql://securevault:securevault@localhost:5434/securevault

# Generate AES-256 key with:
# python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
VAULT_ENCRYPTION_KEY=replace-with-32-byte-base64-encoded-key
